# ============================================================
# Huyền Bí — Biến môi trường
# Sao chép file này thành .env rồi điền giá trị phù hợp
# ============================================================

# --- PostgreSQL ---
POSTGRES_DB=huyenbi
POSTGRES_USER=huyenbi
POSTGRES_PASSWORD=huyenbi_secret

# DATABASE_URL tự động được tạo từ các biến trên trong docker-compose.yml
# Nếu dùng database ngoài (không qua docker-compose), điền trực tiếp:
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Port ---
# Cổng web Nginx expose ra bên ngoài (mặc định: 80)
WEB_PORT=80

# --- AI Providers (tuỳ chọn) ---
# Nếu không điền, người dùng có thể nhập trực tiếp trong giao diện ứng dụng

# OpenAI
OPENAI_API_KEY=sk-...

# Google Gemini
GEMINI_API_KEY=AIza...

# Replit AI Integrations (chỉ dùng khi deploy trên nền tảng Replit)
AI_INTEGRATIONS_OPENAI_BASE_URL=
AI_INTEGRATIONS_OPENAI_API_KEY=
