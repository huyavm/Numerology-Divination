# ============================================================
# Stage 1: Builder — cài deps + build Vite frontend
# ============================================================
FROM node:20-slim AS builder

RUN corepack enable && corepack prepare pnpm@latest --activate

WORKDIR /app

# Cấu hình pnpm:
# - minimum-release-age=0: bỏ giới hạn tuổi package khi build trong Docker
# - supported-architectures: yêu cầu pnpm cài binary native cho cả x64 lẫn arm64 (glibc)
#   Điều này giải quyết lỗi "@rollup/rollup-linux-arm64-gnu not found" trên ARM64 server
RUN printf "minimum-release-age=0\nsupported-architectures-cpu=arm64+x64\nsupported-architectures-os=linux\nsupported-architectures-libc=glibc\n" > /root/.npmrc

# Copy workspace manifest trước để tận dụng layer cache
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml ./

# Copy tất cả package.json trong workspace
COPY artifacts/api-server/package.json          ./artifacts/api-server/
COPY artifacts/mockup-sandbox/package.json      ./artifacts/mockup-sandbox/
COPY artifacts/mysticism-web/package.json       ./artifacts/mysticism-web/
COPY lib/                                       ./lib/

# pnpm sẽ tự tải đúng binary ARM64 nhờ supported-architectures trong .npmrc
RUN pnpm install --no-frozen-lockfile

# Copy toàn bộ source code của frontend + shared libs
COPY artifacts/mysticism-web/ ./artifacts/mysticism-web/
COPY lib/                     ./lib/

# Vite yêu cầu PORT và BASE_PATH lúc build
# PORT chỉ dùng cho dev server — giá trị không quan trọng khi build tĩnh
# BASE_PATH=/ vì app được phục vụ tại root
ENV PORT=3000 \
    BASE_PATH=/ \
    NODE_ENV=production \
    REPL_ID=""

RUN pnpm --filter @workspace/mysticism-web run build
# Output: artifacts/mysticism-web/dist/public/

# ============================================================
# Stage 2: Nginx — phục vụ static files + proxy API
# ============================================================
FROM nginx:1.27-alpine AS runner

# Xoá config mặc định của nginx
RUN rm /etc/nginx/conf.d/default.conf

# Copy nginx config tùy chỉnh
COPY docker/nginx.conf /etc/nginx/conf.d/app.conf

# Copy static files từ builder
COPY --from=builder /app/artifacts/mysticism-web/dist/public /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
